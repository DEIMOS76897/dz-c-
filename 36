#include <iostream>
using namespace std;

int main3() {
    const int n = 5;
    int a[n][n];

    for (int i = 0; i < n; i++) {
        for (int x = 0; x < n; x++) {
            a[i][x] = rand() % 10;
        }
    }

    int s = 0;
    for (int i = 0; i < n; i++) {
        s += a[i][i];
    }

    cout << "all summa: " << s;
    return 0;
}
